  - id:              0
    value:           'double -0.000000e+00'
    alignment:       8
    isTargetSpecific: false
machineFunctionInfo:
  amxProgModel:    None
body:             |
  bb.0 (%ir-block.2):
    successors: %bb.1(0x40000000), %bb.2(0x40000000)
    liveins: $zmm0, $zmm1

    ;CHECK: %1:vr512 = COPY $zmm1
    ;CHECK-NEXT: %0:vr512 = COPY $zmm0
    ;CHECK-NEXT: %2:vr512 = AVX512_512_SET0
    ;CHECK-NEXT: %3:vk8 = nofpexcept VCMPPDZrri %0, killed %2, 12, implicit $mxcsr
    ;CHECK-NEXT: %4:gr32 = COPY %3
    ;CHECK-NEXT: %5:gr8 = COPY %4.sub_8bit
    ;CHECK-NEXT: TEST8rr %5, %5, implicit-def $eflags
    ;CHECK-NEXT: %6:vr512 = nofpexcept VSUBPDZrr %0, %1, implicit $mxcsr
    ;CHECK-NEXT: %7:vr512 = VBROADCASTSDZrm $rip, 1, $noreg, %const.0, $noreg :: (load (s64) from constant-pool)
    ;CHECK-NEXT: %15:gr64 = MOV64rm @counter, 1, $noreg, 0, $noreg
    ;CHECK-NEXT: %15:gr64 = ADD64ri32 %15, 3, implicit-def $eflags
    ;CHECK-NEXT: MOV64mr @counter, 1, $noreg, 0, $noreg, %15
    ;CHECK-NEXT: JCC_1 %bb.2, 4, implicit $eflags

    %1:vr512 = COPY $zmm1
    %0:vr512 = COPY $zmm0
    %2:vr512 = AVX512_512_SET0
    %3:vk8 = nofpexcept VCMPPDZrri %0, killed %2, 12, implicit $mxcsr
    %4:gr32 = COPY %3
    %5:gr8 = COPY %4.sub_8bit
    TEST8rr %5, %5, implicit-def $eflags
    %6:vr512 = nofpexcept VSUBPDZrr %0, %1, implicit $mxcsr
    %7:vr512 = VBROADCASTSDZrm $rip, 1, $noreg, %const.0, $noreg :: (load (s64) from constant-pool)
    JCC_1 %bb.2, 4, implicit $eflags
  
  bb.1 (%ir-block.2):
    successors: %bb.2(0x80000000)
    liveins: $eflags
  
  bb.2 (%ir-block.2):
    successors: %bb.3(0x40000000), %bb.4(0x40000000)
    liveins: $eflags
  
    ;CHECK: %8:vr512 = PHI %7, %bb.1, %1, %bb.0
    ;CHECK-NEXT: %9:vr512 = nofpexcept VADDPDZrr killed %8, %0, implicit $mxcsr
    ;CHECK-NEXT: %16:gr64 = MOV64rm @counter, 1, $noreg, 0, $noreg
    ;CHECK-NEXT: %16:gr64 = ADD64ri32 %16, 1, implicit-def $eflags
    ;CHECK-NEXT: MOV64mr @counter, 1, $noreg, 0, $noreg, %16
    ;CHECK-NEXT: JCC_1 %bb.4, 4, implicit $eflags

    %8:vr512 = PHI %7, %bb.1, %1, %bb.0
    %9:vr512 = nofpexcept VADDPDZrr killed %8, %0, implicit $mxcsr
    JCC_1 %bb.4, 4, implicit $eflags
  
  bb.3 (%ir-block.2):
    successors: %bb.4(0x80000000)
  
  bb.4 (%ir-block.2):
    
    ;CHECK: %10:vr512 = PHI %6, %bb.3, %1, %bb.2
    ;CHECK-NEXT: %11:vr512 = nofpexcept VMULPDZrr killed %10, killed %9, implicit $mxcsr
    ;CHECK-NEXT: %17:gr64 = MOV64rm @counter, 1, $noreg, 0, $noreg
    ;CHECK-NEXT: %17:gr64 = ADD64ri32 %17, 1, implicit-def $eflags
    ;CHECK-NEXT: MOV64mr @counter, 1, $noreg, 0, $noreg, %17
    ;CHECK-NEXT: $zmm0 = COPY %11
    ;CHECK-NEXT: RET 0, $zmm0

    %10:vr512 = PHI %6, %bb.3, %1, %bb.2
    %11:vr512 = nofpexcept VMULPDZrr killed %10, killed %9, implicit $mxcsr
    $zmm0 = COPY %11
    RET 0, $zmm0

...
