# RUN: llc -mtriple x86_64-unknown-linux-gnu --load=%llvmshlibdir/LogicOpsPass_KurakinMatvey_FIIT1_BACKEND%shlibext -run-pass=kurakin-logic-ops-x86 %s -o - | FileCheck %s

# #include <xmmintrin.h>

# __m128 test_and(__m128 a, __m128 b) {
#     return _mm_and_ps(a, b);
# }

# __m128 test_or(__m128 a, __m128 b) {
#     return _mm_or_ps(a, b);
# }

# __m128 test_xor(__m128 a, __m128 b) {
#     return _mm_xor_ps(a, b);
# }

# __m128 test_and_is_copy(__m128 a) {
#     return _mm_and_ps(a, a);
# }

# __m128 test_or_is_copy(__m128 a) {
#     return _mm_or_ps(a, a);
# }

# __m128 test_and_0(__m128 a) {
#     __m128 mask = _mm_castsi128_ps(_mm_set1_epi32(0x0000000));
#     return _mm_and_ps(a,mask);
# }

# __m128 test_or_0(__m128 a) {
#     __m128 mask = _mm_castsi128_ps(_mm_set1_epi32(0x0000000));
#     return _mm_or_ps(a,mask);
# }

# __m128 test_and_1(__m128 a) {
#     __m128 mask = _mm_castsi128_ps(_mm_set1_epi32(0xFFFFFFFF));
#     return _mm_and_ps(a,mask);
# }

# __m128 test_or_1(__m128 a) {
#     __m128 mask = _mm_castsi128_ps(_mm_set1_epi32(0xFFFFFFFF));
#     return _mm_or_ps(a,mask);
# }

--- |
