  entry:
    %0 = bitcast <4 x float> %a to <4 x i32>
    %1 = bitcast <4 x float> %b to <4 x i32>
    %or.i = or <4 x i32> %1, %0
    %2 = bitcast <4 x i32> %or.i to <4 x float>
