body:             |
  bb.0 (%ir-block.0):
    liveins: $xmm0, $xmm1, $xmm2
    %0:fr64 = COPY $xmm0
    %1:fr64 = COPY $xmm1
    %2:fr64 = COPY $xmm2
    ; CHECK:       VFMSUB213SDr
    renamable %3:fr64 = nofpexcept MULSDrr %0, %1, implicit $mxcsr
    renamable %4:fr64 = nofpexcept SUBSDrr %2, killed %3, implicit $mxcsr
    $xmm0 = COPY %4
    RET64 $xmm0


